# Copy to .env.local and fill in real values. Do NOT commit .env.local.
# Restart `npm run dev` after changing env (Next.js reads it at startup).

# --- Comments AI (server-only) -------------------------------------------------
# Provider defaults to OpenAI; only the API key is required to enable real AI.
# Without a key, AI features degrade gracefully to a local deterministic mock.
OPENAI_API_KEY=

# Optional overrides:
# AI_MODEL=gpt-4o-mini
# Point at any OpenAI-compatible provider (no trailing /chat/completions):
# AI_BASE_URL=https://api.openai.com/v1

# --- Realtime collaboration (client) -------------------------------------------
# y-websocket endpoint for presence + record sync. Defaults to local dev server.
# NEXT_PUBLIC_COLLAB_WS_URL=ws://127.0.0.1:1234
